{
	"schemaVersion": 1,
	"id": "vlc-stream",
	"version": "${version}",
	"name": "VLC Stream",
	"description": "Stream anything VLC can open — Twitch, YouTube via yt-dlp, IPTV, RTSP cameras, local files — onto a flat screen in your Minecraft world.",
	"authors": [
		"Valentin Lehmann"
	],
	"contact": {
		"homepage": "https://github.com/valentinlehmann/fabric-vlc-stream",
		"sources": "https://github.com/valentinlehmann/fabric-vlc-stream",
		"issues": "https://github.com/valentinlehmann/fabric-vlc-stream/issues"
	},
	"license": "CC0-1.0",
	"icon": "assets/vlc-stream/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"de.valentinlehmann.VLCStream"
		],
		"client": [
			"de.valentinlehmann.client.VLCStreamClient"
		]
	},
	"mixins": [
		"vlc-stream.mixins.json",
		{
			"config": "vlc-stream.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "${mc_dep}",
		"java": ">=${java_version}",
		"fabric-api": "*"
	},
	"custom": {
		"mc-publish": {
			"modrinth": "ujS6lpVr"
		}
	}
}